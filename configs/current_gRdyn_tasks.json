      "type": "audit",
      "command": "conda run -n globalpose-gpu python streaming_pl_output_audit.py --output-json data/experiments/experiment_orchestrator/current_gRdyn_batch/pl_streaming_audit_original_old_s4.json",
      "dependencies": [],
      "gpu_required": true,
      "estimated_gpu_mem_gb": 4,
